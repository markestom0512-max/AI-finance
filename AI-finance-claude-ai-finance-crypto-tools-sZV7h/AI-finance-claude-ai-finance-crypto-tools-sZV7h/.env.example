ANTHROPIC_API_KEY=your_anthropic_api_key_here

# ── Telegram Scheduler (required for scheduler.py) ──────────────────────────
# 1. Create a bot: message @BotFather on Telegram → /newbot
# 2. Copy the token it gives you below
# 3. Start a chat with your bot, then run:
#    curl https://api.telegram.org/bot<TOKEN>/getUpdates
#    → find your chat_id in the JSON response
TELEGRAM_BOT_TOKEN=your_telegram_bot_token_here
TELEGRAM_CHAT_ID=your_telegram_chat_id_here

# ── Optional: exchange API keys ──────────────────────────────────────────────
# Not required for public market data (OHLCV, order book)
# BINANCE_API_KEY=
# BINANCE_SECRET=
